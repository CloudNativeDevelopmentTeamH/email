{
  "name": "email",
  "version": "1.0.0",
  "description": "Email Service — sends transactional emails triggered by domain events",
  "type": "module",
  "main": "./src/server.ts",
  "scripts": {
    "dev": "nodemon --exec tsx ./src/server.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node ./dist/server.js",
    "setup:rabbitmq": "tsx ./src/messaging/setup-rabbitmq.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^7.0.11",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "nodemon": "^3.1.11",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1"
  },
  "dependencies": {
    "@types/amqplib": "^0.10.8",
    "amqplib": "^0.10.9",
    "dotenv": "^17.2.3",
    "nodemailer": "^7.0.3",
    "pino": "^10.1.0",
    "pino-pretty": "^13.0.0"
  }
